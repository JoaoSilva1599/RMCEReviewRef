  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {323},
  number = {23},
  pages = {3027--3032},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2011.06.052},
  urldate = {2025-07-27},
  abstract = {The effect of demagnetization in a stack of gadolinium plates is determined experimentally by using spatially resolved measurements of the adiabatic temperature change due to the magnetocaloric effect. The number of plates in the stack, the spacing between them and the position of the plate on which the temperature is measured are varied. The orientation of the magnetic field is also varied. The measurements are compared to a magnetostatic model previously described. The results show that the magnetocaloric effect, due to the change in the internal field, is sensitive to the stack configuration and the orientation of the applied field. This may have significant implications for the construction of a magnetic cooling device.},
  keywords = {Adiabatic temperature change,Demagnetizing field,Gadolinium,Numerical model},
