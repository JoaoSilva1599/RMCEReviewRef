  keywords = {Anisotropic magnetoresistance,Crystals,Magnetic anisotropy,Magnetic fields,magnetic refrigeration,Magnetic refrigeration,Magnetization,magnetocaloric materials,Magnetocaloric materials,Perpendicular magnetic anisotropy,Spin-reorientation transition,spin-reorientation transition (SRT),Temperature measurement},
