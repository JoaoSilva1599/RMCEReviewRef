@article{231_2,
  title = {Self-{{Enhancement}} of {{Rotating Magnetocaloric Effect}} in {{Anisotropic Two-Dimensional}} ({{2D}}) {{Cyanido-Bridged MnII}}--{{NbIV Molecular Ferrimagnet}}},
  author = {Konieczny, Piotr and Michalski, {\L}ukasz and Podgajny, Robert and Chorazy, Szymon and Pe{\l}ka, Robert and Czernia, Dominik and Buda, Szymon and Mlynarski, Jacek and Sieklucka, Barbara and Wasiuty{\'n}ski, Tadeusz},
