  author = {Almeida, Rafael and Ventura, Tom{\'a}s and Pinto, Ricardo Moura Costa and Silva, Jo{\~a}o Oliveira and Loewe, Konrad and Kiefe, Rodrigo and Amaral, Jo{\~a}o Sequeira and Ara{\'u}jo, Jo{\~a}o Pedro and Belo, Jo{\~a}o Horta},
  year = 2026,
  month = jan,
  number = {arXiv:2601.23056},
  eprint = {2601.23056},
  primaryclass = {cond-mat},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.23056},
  urldate = {2026-03-03},
  abstract = {La-Fe-Si-based alloys are among the most application-ready magnetocaloric materials for room-temperature magnetic refrigeration. Powder metallurgy methods have been previously demonstrated to successfully produce structures with sub-mm features for magnetic refrigerators in a scalable method. In this work, we explore the rotating magnetocaloric effect (RMCE) present in a 0.27 mm thin plate of sintered and hydrogenated La(Fe,Mn,Si)\$\_\textbraceleft 13\textbraceright\$. The high aspect ratio (\$\textbackslash sim\$50) of the thin plate leads to an anisotropic magnetocaloric effect (MCE), dependent on the relative orientation of the external magnetic field, and an RMCE when the external field is rotated. We find a maximum rotating adiabatic temperature change (\${$\Delta$}T\_\textbraceleft ad\textbraceright\textasciicircum\textbraceleft rot\textbraceright\$) of 1.17 K with the rotation of a 1 T magnetic field and 1.12 K when rotating a 0.6 T magnetic field, a reduction of only 4\% for a 40\% reduction in applied field strength. Magnetostatic computations revealed a considerable rotating isothermal entropy change (\${$\Delta$}S\_\textbraceleft iso\textbraceright\textasciicircum\textbraceleft rot\textbraceright\$), comparable to the conventional MCE of Gd for similar fields, reaching 3.97 J K\$\textasciicircum\textbraceleft -1\textbraceright\$ kg\$\textasciicircum\textbraceleft -1\textbraceright\$ for 1 T and 3.68 J K\$\textasciicircum\textbraceleft -1\textbraceright\$ kg\$\textasciicircum\textbraceleft -1\textbraceright\$ for 0.6 T (7\% reduction), highlighting La-Fe-Mn-Si alloys as high potential candidates for a magnetic refrigerator based on the RMCE utilizing relatively low external magnetic field amplitudes, such as 0.6 T.},
  archiveprefix = {arXiv},
  keywords = {Condensed Matter - Materials Science,Physics - Applied Physics},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\LZVS48W7\\Almeida et al. - 2026 - Rotating Magnetocaloric Effect in Sintered La(Fe,Mn,Si)$_ 13 $H$_z$ Plates.pdf;C\:\\Users\\joaos\\Zotero\\storage\\6A5TSJGH\\2601.html}
}

