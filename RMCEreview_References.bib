}

@article{5,
  title = {Supercritical Hydrothermal Synthesis, Magnetism, and Rotating Magnetocaloric Effect of Fluorocarbonates {{K4}}{{{\emph{RE}}}}2({{CO3}}){{3F4}} ({{{\emph{RE}}}}\,=\,{{Ce}}, {{Pr}}, {{Nd}}, {{Sm}}, {{Eu}}, {{Tb}}, and {{Dy}}) with Rare-Earth Dimers {{{\emph{RE}}}}{{2O12F4}}},
  author = {Tong, Jingfang and Lin, Weijie and Guo, Ruixin and Deng, Zhengzhong and Zhou, Haitao and Guo, Shu and Kuang, Xiaojun},
  year = 2025,
  month = jun,
  journal = {Journal of Alloys and Compounds},
  volume = {1031},
  pages = {180881},
  issn = {0925-8388},
  doi = {10.1016/j.jallcom.2025.180881},
  urldate = {2026-04-01},
  abstract = {Strong magnetic anisotropy in low-dimensional magnets leads to a significant rotating magnetocaloric effect, presenting new opportunities for the exploration of more efficient and streamlined refrigeration systems. In this study, we have successfully synthesized a series of centimeter-scale rare-earth-containing fluorocarbonates, K4RE2(CO3)3F4 (RE = Ce, Pr, Nd, Sm, Eu, Tb, and Dy) through a supercritical hydrothermal method, featuring unique RE2O12F4 magnetic dimers. The above materials' fundamental magnetism has been systematically investigated, and no long-range magnetic transitions were captured above 1.8\,K. Based on the low-temperature specific heat results, the long-range magnetic ordering was found around 0.84\,K and 0.97\,K for K4Tb2(CO3)3F4 and K4Dy2(CO3)3F4, respectively. Furthermore, the anisotropic magnetism of K4Tb2(CO3)3F4 and K4Dy2(CO3)3F4 reveals significant magneto-crystalline anisotropy, with the magnetic field (B) aligned along the RE2O12F4 magnetic dimer, which acts as the easy magnetic axis. The maximum rotating field entropy change, -{$\Delta$}SRmax for K4Tb2(CO3)3F4 reaches approximately 9\,J\,kg-1 K-1 around 17\,K, while for K4Dy2(CO3)3F4, it is approximately 5.5\,J\,kg-1 K-1 near 11\,K, both under a 7\,T field applied along the c-axis. These findings highlight the potential of these compounds for magnetic refrigeration applications through a rotating crystallographic direction.},
  keywords = {Fluorocarbonate,Magnetic dimers,Magnetocaloric effect,Rare-earth,Supercritical hydrothermal},
  file = {C:\Users\joaos\Zotero\storage\3JYE827C\Tong et al. - 2025 - Supercritical hydrothermal synthesis, magnetism, and rotating magnetocaloric effect of fluorocarbona.pdf}
}

