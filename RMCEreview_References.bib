  author = {Skokov, K. P. and Karpenkov, A. Y. and Karpenkov, D. Y. and Radulov, I. A. and G{\"u}nzing, D. and Eggert, B. and Rogalev, A. and Wilhelm, F. and Liu, J. and Shao, Y. and Ollefs, K. and Gruner, M. E. and Wende, H. and Gutfleisch, O.},
