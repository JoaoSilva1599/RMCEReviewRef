  file = {C\:\\Users\\joaos\\Zotero\\storage\\RZZXGM99\\Jin et al. - 2011 - Giant anisotropy of magnetocaloric effect in TbMnO$ _ 3 $ single crystals.pdf;C\:\\Users\\joaos\\Zotero\\storage\\LJFM8D88\\PhysRevB.83.html}
}

