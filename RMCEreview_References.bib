@article{00Barclay,
  title = {A 4 {{K}} to 20 {{K}} Rotational-Cooling Magnetic Refrigerator Capable of {{1mW}} to {$>$} {{1W}} Operation},
  author = {Barclay, J. A.},
  year = 1980,
  month = aug,
  journal = {Cryogenics},
  volume = {20},
  number = {8},
  pages = {467--471},
  issn = {0011-2275},
  doi = {10.1016/0011-2275(80)90081-8},
  urldate = {2026-03-31},
  abstract = {The low-temperature, magnetic entropy of certain single-crystal paramagnetic materials, eg DyPO4 changes dramatically as the crystal rotates in a magnetic field. A new magnetic refrigerator design based on the anisotropic nature of such materials is presented. The key advantages of the rotational-cooling concept are: a single, rotary motion is required; magnetic field shaping is not a problem because the entire working material is in a constant field; and the size of the refrigerator is smaller than other comparable magnetic refrigerators because the working material is entirely inside the magnet at all times. The main disadvantage of the rotational-cooling concept is that small-dimension single crystals are required.},
  file = {C:\Users\joaos\Zotero\storage\KF2W2XK2\0011227580900818.html}
}

@article{10,
  title = {Anisotropic Magnetism and Magnetocaloric Effects in {{{\emph{RE}}}}{{3Ni5Al19}} ({{{\emph{RE}}}}~=~{{Ho}} and {{Er}}) Single Crystals},
  author = {Wang, Sujuan and Luo, Xiaohua and Luo, Qing and Zhong, Rui and Chen, Changcai and Fang, Chunsheng and Rehman, Sajjad Ur and Bulyk, Ihor and He, Wencheng and Ma, Shengcan},
  year = 2025,
  month = feb,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {614},
  pages = {172745},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2024.172745},
  urldate = {2026-03-31},
  abstract = {We report the crystal structure, magnetic properties, and magnetocaloric effect of RE3Ni5Al19 (RE = Ho and Er) single crystals. The rod-like Ho3Ni5Al19 and Er3Ni5Al19 single crystals were grown by Al flux. Powder X-ray diffraction patterns show that Ho3Ni5Al19 and Er3Ni5Al19 exhibit the orthorhombic Gd3Ni5Al19-type structure with space group Cmcm. Magnetic measurements reveal that Ho3Ni5Al19 and Er3Ni5Al19 undergo a paramagnetic (PM)-antiferromagnetic (AFM) transition at 11~K and 2.3~K, respectively. Ho3Ni5Al19 exhibits significant magnetic anisotropy with the easy direction along the a axis, and field-induced multistep metamagnetic transition appears along the a axis below 6~K. In contrast, the easy direction of Er3Ni5Al19 is parallel to the bc plane. The maximum magnetic entropy changes of Ho3Ni5Al19 and Er3Ni5Al19 are -11.9~J/kg K and -13.2~J/kg K under a magnetic field change of 70 kOe. The corresponding values of refrigeration capacity are evaluated to be 256.9~J/kg and 251.1~J/kg, respectively. Moreover, a considerable rotating magnetocaloric effect is also obtained, with the maximum rotating magnetic entropy changes of -8.5~J/kg K and -10.9~J/kg K under 70 kOe for Ho3Ni5Al19 and Er3Ni5Al19, respectively.},
  keywords = {Magnetic refrigeration,Magnetism,Magnetocaloric effect,Single crystals},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\FR4PMNJP\\Wang et al. - 2025 - Anisotropic magnetism and magnetocaloric effects in RE3Ni5Al19 (RE = Ho and Er) single.pdf;C\:\\Users\\joaos\\Zotero\\storage\\S25X958H\\S0304885324010369.html}
}

@article{10,
  title = {Anisotropic Magnetocaloric Effect and First- Principle Calculations on {{Nd2Fe14B}}},
  author = {Elkenany, M. M. and Aly, S. H. and Yehia, Sherif and Westmoreland, Doug and Mohammad, Fatema Z.},
  year = 2025,
  month = jul,
  journal = {Solid State Communications},
  volume = {401},
  pages = {115935},
  issn = {0038-1098},
  doi = {10.1016/j.ssc.2025.115935},
  urldate = {2026-04-01},
  abstract = {This theoretical study investigates the effect of magnetic anisotropy on magnetic and magnetothermal properties of Nd2Fe14B in the temperature range of 78--293~K. Using a classical statistical mechanics based model and the DFT calculations using the VASP code, we determined: magnetization, total heat capacity and magnetocaloric effects (e.g. ({$\Delta$}Sm) and ({$\Delta$}Tad) versus temperature and field strength, along the crystallographic directions [110], [100] and [001]. Electronic and phonon densities of states (DOS) were calculated to determine the electronic heat capacity coefficient and Debye temperature. Elastic constants, bulk and shear moduli were also obtained along with longitudinal, transverse and average sound velocities. Notably our results reveal a maximum {$\Delta$}Tad of 10.5~K in a 3~T field near the spin reorientation temperature along [110], with a relative cooling power RCP (T) of 276~K2},
  keywords = {Anisotropy,Density of states,Elastic properties,Magnetic and magnetothermal properties,VASP code}
}

@article{10.1063/1.2952537,
  title = {Optimization and Improvement of {{Halbach}} Cylinder Design},
  author = {Bj{\o}rk, R. and Bahl, C. R. H. and Smith, A. and Pryds, N.},
  year = 2008,
  month = jul,
  journal = {Journal of Applied Physics},
  volume = {104},
  number = {1},
  eprint = {https://pubs.aip.org/aip/jap/article-pdf/doi/10.1063/1.2952537/15018974/013910\_1\_online.pdf},
  pages = {013910},
  issn = {0021-8979},
  doi = {10.1063/1.2952537},
  abstract = {In this paper we describe the results of a parameter survey of a 16 segmented Halbach cylinder in three dimensions in which the parameters internal radius, rin, external radius, rex, and length, L, have been varied. Optimal values of rex and L were found for a Halbach cylinder with the least possible volume of magnets with a given mean flux density in the cylinder bore. The volume of the cylinder bore could also be significantly increased by only slightly increasing the volume of the magnets, for a fixed mean flux density. Placing additional blocks of magnets on the end faces of the Halbach cylinder also improved the mean flux density in the cylinder bore, especially so for short Halbach cylinders with large rex. Moreover, magnetic cooling as an application for Halbach cylinders was considered. A magnetic cooling quality parameter, {$\Lambda$}cool, was introduced and results showed that this parameter was optimal for long Halbach cylinders with small rex. Using the previously mentioned additional blocks of magnets can improve the parameter by as much as 15\% as well as improve the homogeneity of the field in the cylinder bore.}
}

