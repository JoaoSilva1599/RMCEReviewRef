  urldate = {2025-08-07},
  abstract = {We have developed a method for biaxial texture determination in polycrystalline films using reflection high energy electron diffraction (RHEED) in-plane rocking curves. Experimental RHEED in-plane rocking curves were taken at 25keV and 2.7{$^\circ$} incidence angle from 11nm thick, nominally [100]-textured MgO films grown on amorphous Si3N4 by ion beam-assisted deposition (IBAD). The experimental RHEED in-plane rocking curves were analyzed by comparing them with RHEED in-plane rocking curves calculated using a kinematical simulation. The model enables a quantitative correlation between biaxial texture and RHEED in-plane rocking curve measurements. RHEED results are compared to X-ray rocking curve film analysis.},
