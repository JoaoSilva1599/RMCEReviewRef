}

@article{HTP_RSM,
  title = {Tunable Perpendicular Magnetic Anisotropy in Epitaxial {{Y3Fe5O12}} Films},
  author = {Li, Gang and Bai, He and Su, Jian and Zhu, Z. Z. and Zhang, Ying and Cai, J. W.},
  year = 2019,
