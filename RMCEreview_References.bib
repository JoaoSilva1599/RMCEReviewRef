@article{179,
  title = {Rotating Magnetocaloric Effect in Textured Polycrystalline {{Tb3NiGe2}} Compound with Successive Magnetic Transitions},
  author = {Wang, YiXu and Zhang, Hu and Long, KeWen and Xing, ChengFen and Xiao, YaNing and Su, LiQun and Wang, LiChen and Long, Yi},
  year = 2018,
  month = sep,
  journal = {Intermetallics},
  volume = {100},
  pages = {175--180},
  issn = {0966-9795},
  doi = {10.1016/j.intermet.2018.06.018},
  urldate = {2026-03-31},
  abstract = {The magnetic and rotating magnetocaloric properties in textured Tb3NiGe2 compound were investigated. Two successive magnetic transitions, a ferrimagnetic to antiferromagnetic (AFM)-like transition at Tt\,=\,130\,K and an AFM to paramagnetic (PM)-like transition at TN\,=\,144\,K, are observed. Besides, a magnetic-field-induced antiferromagnetic-ferromagnetic metamagnetic transition occurs in the temperature range of Tt\,{$\sim$}\,TN. Large rotating magnetic entropy changes, together with considerable adiabatic temperature changes and refrigeration capacity, are obtained in textured Tb3NiGe2 compound. Moreover, the equivalence of different calculation methods for rotating magnetocaloric effect (RMCE) is discussed mathematically. The large RMCE with excellent thermal and magnetic reversibility suggests textured Tb3NiGe2 compound as an attractive candidate for novel magnetic refrigerant.},
  keywords = {Adiabatic temperature change,Magnetic entropy change,Metamagnetic transition,Rotating magnetocaloric effect},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\ZE2B2BUX\\Wang et al. - 2018 - Rotating magnetocaloric effect in textured polycrystalline Tb3NiGe2 compound with successive magneti.pdf;C\:\\Users\\joaos\\Zotero\\storage\\WIYBZALL\\S0966979518304229.html}
}

@article{18,
  title = {Room Temperature Magnetocaloric Effects in Monoclinic {{Cr3Te4}}},
  author = {Goswami, Anirban and Ng, Nicholas and Yakubu, Emmanuel and Guchhait, Samaresh},
  year = 2025,
  month = jan,
  journal = {Journal of Applied Physics},
  volume = {137},
  number = {4},
  pages = {043909},
  issn = {0021-8979},
  doi = {10.1063/5.0234906},
  urldate = {2026-04-01},
  abstract = {We report a systematic investigation of anisotropic magnetocaloric effects in a crystalline, monoclinic Cr3Te4 sample grown by the chemical vapor transport (CVT) method. The maximum magnetic entropy change -{$\Delta$}SmaxM is 3.31\,J\,kg-1\,K-1 for the c axis (3.16\,J\,kg-1\,K-1 for the ab-plane) and the relative cooling power (RCP) is 340\,J\,kg-1 for the c axis (350\,J\,kg-1 for the ab-plane) near the Curie temperature with a magnetic field ({$\mu$}0H) change of 9\,T. With the scaling analysis of {$\Delta$}SM, all rescaled {$\Delta$}SM(T, H) curves collapse onto a single universal curve, indicating a second-order magnetic phase transition in Cr3Te4. Furthermore, -{$\Delta$}SmaxM follows the power law of Hn with n\,=\,0.656\,\textpm\,0.005. The RCP and {$\delta$}TFWHM have Hc and Hb dependence on field, with c\,=\,1.179\,\textpm\,0.011 and b\,=\,0.498\,\textpm\,0.005, respectively, which led us to estimate the critical exponents of {$\beta$}\,=\,0.359\,\textpm\,0.013, {$\gamma$}\,=\,1.646\,\textpm\,0.057, and {$\delta$}\,=\,5.578\,\textpm\,0.190.}
}

@article{180,
