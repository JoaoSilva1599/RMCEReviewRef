  journal = {Inorganic Chemistry},
  volume = {56},
  number = {5},
  pages = {2777--2783},
  publisher = {American Chemical Society},
  issn = {0020-1669},
  doi = {10.1021/acs.inorgchem.6b02941},
  urldate = {2026-03-31},
  abstract = {The rotating magnetocaloric effect (RMCE) is a new issue in the field of magnetic refrigeration. We have explored this subject on the two-dimensional (2D) enantiopure \textbraceleft [MnII(R-mpm)2]2[NbIV(CN)8]\textbraceright{$\cdot$}4H2O (where mpm = {$\alpha$}-methyl-2-pyridinemethanol) coordination ferrimagnet. In this study, the magnetic and magnetocaloric properties of single crystals were investigated along the bc//H easy plane and the a*//H hard axis. The observed small easy plane anisotropy is due to the dipole--dipole interactions. For fields higher than 0.5 T, no significant difference in the magnetocaloric effect between both geometries was noticed. The maximal magnetic entropy change for conventional effect was observed at 32 K and the magnetic field change {$\mu$}0{$\Delta$}H = 5.0 T attaining the value of {$\sim$}5 J mol--1 K--1. The obtained maximal value of -{$\Delta$}Sm is comparable to previously reported results for polycrystalline octacyanidoniobate-based bimetallic coordination polymers. A substantial anisotropy of magnetocaloric effect between the easy plane and hard axis appears in low fields. This includes the presence of inverse magnetocaloric effect only for the a*//H direction. The difference between both geometries was used to study the rotating magnetocaloric effect. We show that the inverse part of magnetocaloric effect can be used to enhance the rotating magnetic entropy change up to 51\%. This finding is of key importance for searching efficient materials for RMCE.},
  file = {C:\Users\joaos\Zotero\storage\Y6H2ZWKM\Konieczny et al. - 2017 - Self-Enhancement of Rotating Magnetocaloric Effect in Anisotropic Two-Dimensional (2D) Cyanido-Bridg.pdf}
}

@article{240,
  title = {Large Rotating Magnetocaloric Effect in the Orthorhombic {{DyMnO3}} Single Crystal},
