  journal = {Journal of Superconductivity and Novel Magnetism},
  volume = {33},
  number = {9},
  pages = {2875--2879},
  issn = {1557-1947},
  doi = {10.1007/s10948-020-05548-5},
  urldate = {2025-06-02},
  abstract = {In this work, the magnetic properties and rotating magnetocaloric effect in NdMnO3 perovskite have been investigated by using the Monte Carlo simulations. The rotating magnetocaloric effect is obtained from various temperature dependencies of magnetization in different magnetic fields for two perpendicular orientations (h {$\parallel$} c and h {$\perp$} c). The magnetization and specific heat with the temperature are given for different external magnetic fields. The Curie temperature and magnetic entropy change for various external magnetic field are obtained as well. Finally, the dependence of external magnetic field on relative cooling power is presented.},
