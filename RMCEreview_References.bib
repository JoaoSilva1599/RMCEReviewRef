@incollection{pecharskyGiantMagnetocaloricEffect1998,
  title = {The {{Giant Magnetocaloric Effect}} in {{Gd5}}({{SixGe1-x}})4 {{Materials}} for {{Magnetic Refrigeration}}},
  booktitle = {Advances in {{Cryogenic Engineering}}},
  author = {Pecharsky, V. K. and Gschneidner, K. A.},
