@misc{522_Rafa,
  title = {Rotating {{Magnetocaloric Effect}} in {{First-order Phase Transition Material Gd5Si2Ge2}}},
  author = {Almeida, Rafael and Kiefe, Rodrigo and Pinto, Ricardo Moura Costa and Amaral, Jo{\~a}o Sequeira and {Dixon-Anderson}, Kyle and Mudryk, Yaroslav and Ara{\'u}jo, Jo{\~a}o Pedro and Belo, Jo{\~a}o Horta},
  year = 2026,
  month = jan,
  number = {arXiv:2601.13239},
  eprint = {2601.13239},
  primaryclass = {cond-mat},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.13239},
  urldate = {2026-03-03},
  abstract = {The rotating magnetocaloric effect (RMCE) induced by self-demagnetization has been investigated in the giant magnetocaloric effect (GMCE) material Gd\$\_5\$Si\$\_2\$Ge\$\_2\$. This shape-dependent effect had thus far only been reported in pure Gd, marking this as the first analysis of the effect in a sample with a magnetostructural first-order phase transition. By rotating the applied magnetic field vector while keeping its intensity constant, the demagnetizing field within a high-aspect ratio sample changes significantly, resulting in a RMCE. We characterize RMCE by determining the adiabatic temperature change (\${$\Delta$}T\_\textbraceleft ad\textbraceright\textasciicircum\textbraceleft rot\textbraceright\$) directly through temperature measurements, and the isothermal entropy change (\${$\Delta$}S\_M\textasciicircum\textbraceleft rot\textbraceright\$) via magnetometry and magnetostatic simulations. We obtain a remarkable maximum \${$\Delta$}T\_\textbraceleft ad\textbraceright\textasciicircum\textbraceleft rot\textbraceright\$ of 1.77 K for a constant external field of 0.8 T, higher than that obtained under 1.0 T. The magnetostatic simulations not only corroborate the highly non-monotonous field-dependence of \$\textbar{$\Delta$}S\_\textbraceleft M\textbraceright\textasciicircum\textbraceleft rot\textbraceright\textbar\$, which reaches 95\textbackslash\% of its maximum value at 0.8 T, 6.12 J K\$\textasciicircum\textbraceleft -1\textbraceright\$ kg\$\textasciicircum\textbraceleft -1\textbraceright\$ for the experimentally measured shape, but also estimate a 35\textbackslash\% increase in the maximum \$\textbar{$\Delta$}S\_\textbraceleft M\textbraceright\textasciicircum\textbraceleft rot\textbraceright\textbar\$ up to 8.67 J K\$\textasciicircum\textbraceleft -1\textbraceright\$ kg\$\textasciicircum\textbraceleft -1\textbraceright\$ in a simulated shape with higher aspect ratio.},
  archiveprefix = {arXiv},
  keywords = {Condensed Matter - Materials Science,Physics - Applied Physics},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\K8EPMDXM\\Almeida et al. - 2026 - Rotating Magnetocaloric Effect in First-order Phase Transition Material Gd5Si2Ge2.pdf;C\:\\Users\\joaos\\Zotero\\storage\\98C4D4AA\\2601.html}
}

@article{amaralEstimatingMagnetocaloricEffect2010,
  title = {On Estimating the Magnetocaloric Effect from Magnetization Measurements},
  author = {Amaral, J. S. and Amaral, V. S.},
  year = 2010,
  month = may,
  journal = {Journal of Magnetism and Magnetic Materials},
  series = {Proceedings of the {{Joint European Magnetic Symposia}}},
  volume = {322},
  number = {9},
  pages = {1552--1557},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2009.06.013},
  urldate = {2025-09-29},
  abstract = {We address various aspects on estimating the magnetocaloric effect from magnetization measurements, and the use of a Maxwell relation in first- and second-order phase transitions, including (a) the use of magnetization as a thermodynamic variable in an inhomogeneous situation (structural or chemical distributions, magnetic domains) and (b) non-equilibrium conditions (irreversibility) on first-order phase transitions, including mixed-phase conditions. We find that the Maxwell equation or any other methods such as area differentiation should be used with caution and not include data out of equilibrium, which can lead to spurious results. The use of methods for modeling the magnetic entropy change of first- and second-order magnetic phase transitions, such as Landau and mean-field theory, can be helpful to better understand the nature of the commonly found anomalous peaks in magnetic entropy change and their physical relevance.},
  keywords = {Magnetic entropy,Magnetocaloric effect,Phase transition},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\F7ZG9AYE\\Amaral e Amaral - 2010 - On estimating the magnetocaloric effect from magnetization measurements.pdf;C\:\\Users\\joaos\\Zotero\\storage\\R92TI8UY\\S0304885309006398.html}
}

@article{ammonia,
  title = {A {{Review}} of {{Safety Issues}} and {{Risk Assessment}} of {{Industrial Ammonia Refrigeration System}}},
  author = {Khudhur, Dheyaa Ashour and Tuan Abdullah, Tuan Amran and Norazahar, Norafneeza},
  year = 2022,
  month = sep,
  journal = {ACS Chemical Health \& Safety},
  volume = {29},
  number = {5},
  pages = {394--404},
  publisher = {American Chemical Society},
  doi = {10.1021/acs.chas.2c00041},
  urldate = {2025-07-18},
  abstract = {Several industries like cold storage and ice plants heavily rely on ammonia (NH3) due to its low cost, excellent thermophysical traits, and zero effects on the ozone layer. Despite its widespread use as a refrigerant, the hazardous nature of ammonia remains a significant health concern. Since the industrial revolution, ammonia leakage has led to numerous major accidents, including fire and vapor cloud explosions. This paper reviews the safety issues and the current practices of risk assessment with regard to the industrial ammonia used in refrigeration systems. In addition, previous works related to the risk analysis of ammonia-based industries are reviewed. The majority of ammonia refrigeration system-related works applied the traditional static tools for risk analysis such as fault tree, event tree, and bow-tie that are not suitable to handle common causes of failures or conditional dependencies, which are absolutely significant aspects for a reliable safety assessment. Thus, it is vital to maintain and improve the safety levels of diverse industries using ammonia-based refrigeration systems. Various characteristics of ammonia-based refrigeration systems and their safety issues related to industry, present development, and future trends are comprehensively underscored. This review may act as a guide to develop a better understanding of dealing effectively with the hazards of ammonia-based refrigeration systems and risk assessment, thus enhancing the overall safety of humans and the environment.}
}

@article{andradeFreestandingFlexibleComposites2020,
  title = {Freestanding and Flexible Composites of Magnetocaloric {{Gd5}}({{Si}},{{Ge}})4 Microparticles Embedded in Thermoplastic Poly(Methyl Methacrylate) Matrix},
  author = {Andrade, Vivian M. and Barroca, Nathalie B. and Pires, Ana L. and Belo, Jo{\~a}o H. and Pereira, Andr{\'e} M. and Pirota, Kleber R. and Ara{\'u}jo, Jo{\~a}o P.},
  year = 2020,
  month = jan,
  journal = {Materials \& Design},
  volume = {186},
  pages = {108354},
  issn = {0264-1275},
  doi = {10.1016/j.matdes.2019.108354},
  urldate = {2025-09-29},
  abstract = {The implementation of processed magnetic materials onto thermoplastics can be an approach for practical use of brittle intermetallic materials on device development with the advantage of enlarging the range of applications. In this paper, we present the evaluation on the effect of blending magnetocaloric Gd5Si2.4Ge1.6 3.4\,{$\mu$}m particles with in different weight fractions onto a flexible, transparent and non-magnetic poly(methyl methacrylate) (PMMA). A close to homogeneous grain distribution along the polymer surface were achieved by using a simple solvent casting method for their magnetocaloric properties studies. From XRD analysis, it was found a unit cell volume shrinkage by increasing the powder concentration followed by a reduction on the amount of secondary monoclinic phase as a result of interfacial interactions. As a consequence, a weakening of secondary phases effect on the composite magnetocaloric behavior is observed as a result of the effective hydrostatic pressure from the difference between thermal expansions of matrix and filler.},
  keywords = {Blended microparticles,Flexible composite,Magnetic composite,Magnetocaloric effect},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\WXKNPCU2\\Andrade et al. - 2020 - Freestanding and flexible composites of magnetocaloric Gd5(Si,Ge)4 microparticles embedded in thermo.pdf;C\:\\Users\\joaos\\Zotero\\storage\\R3PX9LM6\\S0264127519307920.html}
}

@article{badosa,
  title = {Demagnetizing Field-Induced Magnetocaloric Effect in {{Gd}}},
  author = {Badosa, Quim and Ma{\~n}osa, Llu{\'i}s and Vives, Eduard and Planes, Antoni and Weise, Bruno and Beyer, Lukas and {Stern-Taulats}, Enric},
  year = 2023,
  month = sep,
  journal = {Journal of Applied Physics},
  volume = {134},
  number = {11},
  pages = {113902},
  issn = {0021-8979},
  doi = {10.1063/5.0161334},
  urldate = {2025-07-20},
  abstract = {We have studied the impact of demagnetizing fields on the magnetocaloric effect of commercial-grade gadolinium plates. Adiabatic temperature changes (  {$\Delta$} T) were measured for magnetic fields applied along the parallel and perpendicular directions of the plates. The differences in the obtained   {$\Delta$} T values were accounted for by differences in the internal field due to demagnetizing effects. A combination of calorimetric measurements under a magnetic field and thermometric measurements has enabled us to obtain Brayton cycles for the two different magnetic field orientations. It has been found that the refrigerant capacity for a Brayton cycle working at 1.6\,T around room temperature reduces from   R C = 9.4 to   R C = 5.5\,J\,kg     - 1 when the demagnetizing factor changes from    N  D\,=\,0.035 to    N  D = 0.928 for the parallel and perpendicular configurations, respectively. It has been shown that it is possible to obtain significant demagnetizing field-induced magnetocaloric effects by rotating the sample in a region of a constant applied magnetic field. The refrigerant capacity of a Brayton cycle around room temperature for a   1.6 T constant applied magnetic field is   R C = 0.6\,J\,kg     - 1. The feasibility of these demagnetizing field-induced effects has been confirmed by direct thermometric measurements, which reveal adiabatic temperature changes of 1\,K when the sample is rotated between the perpendicular and parallel configurations.},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\8KFDDMA2\\Badosa et al. - 2023 - Demagnetizing field-induced magnetocaloric effect .pdf;C\:\\Users\\joaos\\Zotero\\storage\\PHLZKG22\\Demagnetizing-field-induced-magnetocaloric-effect.html}
}

@article{bahl2009,
  title = {The Effect of Demagnetization on the Magnetocaloric Properties of Gadolinium},
  author = {Bahl, C. R. H. and Nielsen, K. K.},
  year = 2009,
  month = jan,
  journal = {Journal of Applied Physics},
  volume = {105},
  number = {1},
  pages = {013916},
  issn = {0021-8979},
  doi = {10.1063/1.3056220},
  urldate = {2025-07-27},
  abstract = {Gadolinium displays a strong magnetocaloric effect at temperatures close to room temperature making it useful in the field of room temperature magnetic refrigeration. We discuss the importance of including the effects of the demagnetization field when considering the magnetocaloric properties of gadolinium. The adiabatic temperature change {$\Delta$}Tad of gadolinium sheets upon application of a magnetic field has been measured at a range of applied magnetic fields and sample orientations. A significant dependence of {$\Delta$}Tad on the sample orientation is observed. This can be accounted for by the demagnetization factor. Also, the temperature dependence of {$\Delta$}Tad has been measured experimentally and modeled by mean field theory. Corrections to mean field theory modeling due to the demagnetization field are proposed and discussed.},
  file = {C:\Users\joaos\Zotero\storage\EAXN46XX\The-effect-of-demagnetization-on-the.html}
}

@article{Barclay_1st,
  title = {A 4 {{K}} to 20 {{K}} Rotational-Cooling Magnetic Refrigerator Capable of {{1mW}} to {$>$} {{1W}} Operation},
  author = {Barclay, J. A.},
  year = 1980,
