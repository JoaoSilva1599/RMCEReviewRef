@article{caronDeterminationMagneticEntropy2009,
  title = {On the Determination of the Magnetic Entropy Change in Materials with First-Order Transitions},
  author = {Caron, L. and Ou, Z. Q. and Nguyen, T. T. and Cam Thanh, D. T. and Tegus, O. and Br{\"u}ck, E.},
  year = 2009,
  month = nov,
  journal = {Journal of Magnetism and Magnetic Materials},
  series = {Current {{Perspectives}}: {{Magnetocaloric Materials}}},
  volume = {321},
  number = {21},
  pages = {3559--3566},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2009.06.086},
  urldate = {2025-10-07},
  abstract = {An accurate method to determine the magnetic entropy change in materials with hysteretic first-order transitions is presented, which is needed to estimate their potential for applications. We have investigated the effect of the maximal entropy change derived from magnetization measurements performed in different measurement processes. The results show that the isothermal entropy change can be derived from the Maxwell relations even for samples with large thermal hysteresis. In the temperature region with hysteresis, overestimating the entropy change can be avoided by measuring the isothermal magnetization of the sample after it is cooled from the paramagnetic state to the measurement temperature. In this way the so-called peak effect is not observed as shown here for a few compounds.},
  keywords = {First-order transition,Magnetic entropy,Magnetic refrigeration,Magnetization process},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\NIGD7DES\\Caron et al. - 2009 - On the determination of the magnetic entropy change in materials with first-order transitions.pdf;C\:\\Users\\joaos\\Zotero\\storage\\W77G9ECE\\S0304885309006787.html}
}

