  file = {C\:\\Users\\joaos\\Zotero\\storage\\WXKNPCU2\\Andrade et al. - 2020 - Freestanding and flexible composites of magnetocaloric Gd5(Si,Ge)4 microparticles embedded in thermo.pdf;C\:\\Users\\joaos\\Zotero\\storage\\R3PX9LM6\\S0264127519307920.html}
}

