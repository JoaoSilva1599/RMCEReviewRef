@article{UL_6,
  title = {Magnetocaloric Effect: {{From}} Materials Research to Refrigeration Devices},
  shorttitle = {Magnetocaloric Effect},
  author = {Franco, V. and Bl{\'a}zquez, J. S. and Ipus, J. J. and Law, J. Y. and {Moreno-Ram{\'i}rez}, L. M. and Conde, A.},
