  abstract = {The performance of magnetocaloric effect materials is one of the key factors restricting the development of magnetic refrigeration technology. Materials with anisotropic magnetocaloric effect can be used in the rotary magnetic refrigeration technology, which is beneficial to the simplification of refrigeration devices. In this work, the magnetic properties, magnetocaloric effects, and magnetic anisotropies of rapidly quenched HoCoSi compounds are investigated. At low temperatures below \emph{T}\textsubscript{t} = 5.7 K, the HoCoSi ferromagnetism and helical magnetism coexist. With the increase of temperature, the HoCoSi undergoes a second-order phase transition from ferromagnetic (FM) to paramagnetic (PM) phase at \emph{T}\textsubscript{C} = 13.7 K. Both XRD and SEM show that the HoCoSi has a preferred orientation. In order to obtain a large magnetocaloric effect and to determine the effect of preferred orientation on magnetism and magnetocaloric effect, the isothermal magnetization curves of the 10 m/s--HoCoSi fast quenched belt in the directions of \emph{H} parallel  and perpendicular to texture around the Curie temperature are analyzed. The corresponding magnetic entropy change (--{$\Delta$}\emph{S}\textsubscript{M}) and magnetic refrigeration capacity (RC) are calculated. Under the magnetic field changing from 0 to 5 T, the value of --{$\Delta$}\emph{S}\textsubscript{M} is 22 J/(kg{$\cdot$}K) in the direction of \emph{H} parallel to the texture and 12 J/(kg{$\cdot$}K) in the direction of \emph{H} perpendicular to texture , and their corresponding values of RC(RCP)are 360 (393.8) J{$\cdot$}kg\textsuperscript{--1} and 160 (254.4) J/kg. The value of --{$\Delta$}\emph{S}\textsubscript{M} reaches 12.5 J/(kg{$\cdot$}K)even at \emph{{$\mu$}}\textsubscript{0}\emph{H} = 0--2 T in the direction of H parallel to the texture. It is obvious that the 10-m/s-HoCoSi fast quenching belt shows a large low-field magnetocaloric effect and obvious magnetic anisotropy, which is expected to be used to realize the magnetic refrigeration technology of rotating samples.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  langid = {chinese},
  file = {C:\Users\joaos\Zotero\storage\X9ZUU8FP\Yan et al. - 2022 - Magnetic and anisotropic magnetocaloric effects of HoCoSi fast quenching ribbons.pdf}
}

@article{97,
  title = {Structure, Magnetic Anisotropy and Magnetocaloric Effect of {{Mn5Ge3-xSix}} Single Crystals},
  author = {Yang, Tonghan and He, Wei and Chen, Feikuo and He, Cuiyun},
  year = 2022,
  month = oct,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {559},
  pages = {169539},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2022.169539},
  urldate = {2026-03-31},
  abstract = {Magnetocaloric polycrystalline materials based on Mn5Ge3 have been widely studied due to their potential application for room temperature magnetic refrigeration. However, many investigations are performed on polycrystalline materials and thus the strong anisotropy in this layered structure is usually neglected. In this study, Mn5Ge3-xSix (x~=~0, 0.7) single crystals were successfully synthesized via Sn flux and characterized by single-crystal X-ray diffraction and magnetic measurements. The Si substitution does not change the structural symmetry, but reduces the shortest Mn~-~Mn distances. As described by the Bethe-Slater curve, the reduction of the shortest Mn~-~Mn distances leads to weaker magnetic exchange, accounting for the lower ordering temperature. The magnetocrystalline anisotropy was evaluated by the Sucksmith and Thompson method, and became smaller upon substitution. The anisotropy constants K1 and K2 of Mn5Ge3-xSix (x~=~0, 0.7) single crystals are positive, and decrease with the temperature. The electron paramagnetic resonance spectra suggest high spin d5 configuration of manganese in both crystals. The easy magnetization direction yields much larger maximum entropy changes in both crystals: 6.0~J/kg K for the pristine and 5.4~J/kg K for the substituted under an applied field of 30 kOe.},
  keywords = {Exchange interactions,Magnetic anisotropy,Magnetocaloric effect,Single crystal},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\V2BRHER9\\Yang et al. - 2022 - Structure, magnetic anisotropy and magnetocaloric effect of Mn5Ge3-xSix single crystals.pdf;C\:\\Users\\joaos\\Zotero\\storage\\563BUBZV\\S0304885322004607.html}
}

@article{amaralEstimatingMagnetocaloricEffect2010,
  title = {On Estimating the Magnetocaloric Effect from Magnetization Measurements},
  author = {Amaral, J. S. and Amaral, V. S.},
  year = 2010,
  month = may,
  journal = {Journal of Magnetism and Magnetic Materials},
  series = {Proceedings of the {{Joint European Magnetic Symposia}}},
  volume = {322},
  number = {9},
  pages = {1552--1557},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2009.06.013},
  urldate = {2025-09-29},
  abstract = {We address various aspects on estimating the magnetocaloric effect from magnetization measurements, and the use of a Maxwell relation in first- and second-order phase transitions, including (a) the use of magnetization as a thermodynamic variable in an inhomogeneous situation (structural or chemical distributions, magnetic domains) and (b) non-equilibrium conditions (irreversibility) on first-order phase transitions, including mixed-phase conditions. We find that the Maxwell equation or any other methods such as area differentiation should be used with caution and not include data out of equilibrium, which can lead to spurious results. The use of methods for modeling the magnetic entropy change of first- and second-order magnetic phase transitions, such as Landau and mean-field theory, can be helpful to better understand the nature of the commonly found anomalous peaks in magnetic entropy change and their physical relevance.},
  keywords = {Magnetic entropy,Magnetocaloric effect,Phase transition},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\F7ZG9AYE\\Amaral e Amaral - 2010 - On estimating the magnetocaloric effect from magnetization measurements.pdf;C\:\\Users\\joaos\\Zotero\\storage\\R92TI8UY\\S0304885309006398.html}
}

@article{ammonia,
  title = {A {{Review}} of {{Safety Issues}} and {{Risk Assessment}} of {{Industrial Ammonia Refrigeration System}}},
  author = {Khudhur, Dheyaa Ashour and Tuan Abdullah, Tuan Amran and Norazahar, Norafneeza},
  year = 2022,
  month = sep,
  journal = {ACS Chemical Health \& Safety},
  volume = {29},
  number = {5},
  pages = {394--404},
  publisher = {American Chemical Society},
  doi = {10.1021/acs.chas.2c00041},
  urldate = {2025-07-18},
  abstract = {Several industries like cold storage and ice plants heavily rely on ammonia (NH3) due to its low cost, excellent thermophysical traits, and zero effects on the ozone layer. Despite its widespread use as a refrigerant, the hazardous nature of ammonia remains a significant health concern. Since the industrial revolution, ammonia leakage has led to numerous major accidents, including fire and vapor cloud explosions. This paper reviews the safety issues and the current practices of risk assessment with regard to the industrial ammonia used in refrigeration systems. In addition, previous works related to the risk analysis of ammonia-based industries are reviewed. The majority of ammonia refrigeration system-related works applied the traditional static tools for risk analysis such as fault tree, event tree, and bow-tie that are not suitable to handle common causes of failures or conditional dependencies, which are absolutely significant aspects for a reliable safety assessment. Thus, it is vital to maintain and improve the safety levels of diverse industries using ammonia-based refrigeration systems. Various characteristics of ammonia-based refrigeration systems and their safety issues related to industry, present development, and future trends are comprehensively underscored. This review may act as a guide to develop a better understanding of dealing effectively with the hazards of ammonia-based refrigeration systems and risk assessment, thus enhancing the overall safety of humans and the environment.}
}

@article{andradeFreestandingFlexibleComposites2020,
