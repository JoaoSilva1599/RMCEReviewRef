  title = {Spin Switching and Magnetocaloric Effect of High-Entropy Orthoferrite Single Crystal},
  author = {Peng, Haohuan and Ma, Xiaoxuan and Yang, Wanting and Lin, Zhaodi and Zheng, Yubing and Sun, Zhiqiang and Song, Huan and Zhang, Yifeng and Kang, Baojuan and Jia, Rongrong and Feng, Zhenjie and Cao, Shixun},
  year = 2024,
  month = sep,
  journal = {Ceramics International},
  volume = {50},
  number = {18, Part A},
  pages = {32288--32294},
  issn = {0272-8842},
  doi = {10.1016/j.ceramint.2024.06.036},
  urldate = {2026-04-01},
  abstract = {The concept of high-entropy oxides/alloys was introduced into the rare-earth orthoferrite (RFeO3, R represents a rare-earth ion) system. Doping five different rare-earth ions with equal molar ratios at the R-site, a single crystal of high-entropy orthoferrite (Y0.2Sm0.2Eu0.2Gd0.2Er0.2)FeO3 (HERFO) was synthesized using optical floating zone method. At high temperatures, the weak ferromagnetic (wFM) moments induced by the distortion of the Fe sublattices align along the c axis, with a spin configuration of {$\Gamma$}4. As the temperature decreases, a spin reorientation transition (SRT) occurs from {$\Gamma$}4 to {$\Gamma$}2 due to the Fe3+-R3+ super-exchange interactions, with an immediate state {$\Gamma$}24. The wFM moments gradually rotate from the c axis to the a axis within the ac plane. In the zero-field-cooling (ZFC) mode, both the type-I and type-II spin switching (SSW) are observable along the a axis. Under low magnetic fields, the type-II SSW is magnetically controlled. The trigger temperature and variation in net moment of the type-II SSW exhibit systematic changes concerning the applied magnetic field. The rich magnetic phase transitions in HERFO make it a promising candidate for spintronic applications aimed at spin manipulation. Additionally, HERFO single crystal exhibits a large magnetocaloric effect (MCE) and magnetic entropy anisotropy, with the negative magnetic entropy change (-{$\Delta$}Sm) along the c axis (14.45~J/(kg{$\cdot$}K)) being greater than that along the a and b axes (9.57~J/(kg{$\cdot$}K) and 10.32~J/(kg{$\cdot$}K)). Consequently, HERFO holds great promise as a novel material for magnetic refrigeration applications aimed at achieving rotational magnetic cooling.},
  keywords = {High-entropy orthoferrite,Magnetocaloric effect,Spin reorientation transition,Spin switching},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\LDPC6BQK\\Peng et al. - 2024 - Spin switching and magnetocaloric effect of high-entropy orthoferrite single crystal.pdf;C\:\\Users\\joaos\\Zotero\\storage\\GMBYCDJT\\S0272884224024428.html}
}

@article{43,
  title = {Direct and Inverse Magnetocaloric Effects in Magnetostrictive {{GdMn2Ge2}} with Field-Induced Metamagnetic Transition},
  author = {Li, Canglong and Li, Zhaohu and Yang, Wenqian and Tian, Zhaoming and Qiu, Yang and Hua, Junfan and Huang, Shuai},
  year = 2024,
  month = jul,
  journal = {Applied Physics Letters},
  volume = {125},
  number = {1},
  pages = {012404},
  issn = {0003-6951},
  doi = {10.1063/5.0207338},
  urldate = {2026-04-01},
  abstract = {Heavy rare-earth-based ternary intermetallic compounds with the formula RT2X2 have drawn great interest because of their multiple magnetic transitions and various magnetic structures. Here, anisotropic magnetic behaviors, magnetocaloric effects (MCEs), and magnetostriction effects in single-crystalline GdMn2Ge2 are studied in two different directions. Experiments show a magnetic transition characterized by a sudden decrease in magnetization for {$\mu$}0H//a and a sharp increase for {$\mu$}0H//c at Tt. The transition is driven by lower temperatures for {$\mu$}0H//a, contrasting that for {$\mu$}0H//c with an increase in the magnetic field. An inverse MCE is observed for {$\mu$}0H//a with a maximum magnetic entropy change (   - {$\Delta$}  S M  max) of -7.4\,J\,kg-1\,K-1 ({$\mu$}0{$\Delta$}H\,=\,6 T), while a direct MCE is obtained for {$\mu$}0H//c with an    - {$\Delta$}  S M  max of 8.0\,J\,kg-1\,K-1 under the same magnetic field change. Moreover, a remarkable field-induced metamagnetic transition and a magnetostriction effect are observed simultaneously at Tt, indicating strong magneto-lattice coupling. The T-{$\mu$}0H phase diagrams are constructed based on the magnetic properties. The coexistence of direct and inverse MCEs is discussed and is due to the spin-flop of Mn and anisotropic magnetic properties under magnetic fields in different directions.},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\38YUKQLX\\Li et al. - 2024 - Direct and inverse magnetocaloric effects in magnetostrictive GdMn2Ge2 with field-induced metamagnet.pdf;C\:\\Users\\joaos\\Zotero\\storage\\6ZF3A2J3\\5.html}
}

@article{45,
  title = {Structure, Magnetic and Magnetocaloric Properties of the {{Mn5Ge3}} Thin Film Grown on {{Si}}(111)},
  author = {Tarasov, A. S. and Komogortsev, S. V. and Lukyanenko, A. V. and Yakovlev, I. A. and Tarasov, I. A. and Sukhachev, A. L. and Rautskii, M. V. and Solovyov, L. A. and Andryushchenko, T. A. and Bondarev, I. A. and Varnakov, S. N. and Volkov, N. V.},
  year = 2024,
  month = jun,
  journal = {Journal of Materials Science},
  volume = {59},
  number = {21},
  pages = {9423--9436},
  issn = {1573-4803},
  doi = {10.1007/s10853-024-09755-6},
  urldate = {2026-04-01},
  abstract = {Mn5Ge3 is a ferromagnetic hexagonal crystal promising for spintronics and magnetocalorics. A systematic study and analysis of the magnetic properties of the Mn5Ge3 thin film grown on Si(111) were performed. The magnetic anisotropy of the film is determined by the shape anisotropy and the easy magnetization axis aligned along the c axis of the crystal. The uniaxial anisotropy constant Ku fully corresponds to that for a bulk single crystal, which indicates that c axis coincides with film normal. Mn5Ge3 film demonstrates high saturation magnetization MS\,=\,900~emu/cm3 (900~kA/m) at T\,=\,100~K and magnetocaloric effect {$\Delta$}S\,=\,3.16\,\textpm\,0.22~J~kg-1~K-1 at 300~K and B\,=\,1.5~T. {$\Delta$}S is comparable to that for multicomponent or Gd rare earth films. Furthermore, a different anisotropy of the magnetocaloric effect compared to bulk Mn5Ge3 was found, which may be related to the anisotropy of the film shape and, possibly, to the domain structure. The results obtained are promising for the design and development of magnetocaloric, spintronic, and spin-caloritronic devices on a silicon platform.},
  langid = {english},
  file = {C:\Users\joaos\Zotero\storage\KH44HH5K\Tarasov et al. - 2024 - Structure, magnetic and magnetocaloric properties of the Mn5Ge3 thin film grown on Si(111).pdf}
