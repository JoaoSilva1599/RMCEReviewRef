@article{46,
  title = {High {{Magnetic Anisotropy}} and {{Magnetocaloric Effects}} in {{Single-Crystal Cr2Te3}}},
  author = {Goswami, Anirban and Ng, Nicholas and Abeykoon, AM Milinda and Yakubu, Emmanuel and Guchhait, Samaresh},
  year = 2024,
