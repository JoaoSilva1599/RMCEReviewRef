  pages = {385001},
  publisher = {IOP Publishing},
  issn = {0022-3727},
  doi = {10.1088/1361-6463/aa7ebc},
  urldate = {2025-07-27},
  abstract = {Isothermal magnetization measurements were performed on a square cuboid shaped polycrystalline sample with a field applied along different directions, having different demagnetization factor values. The magnetocaloric property, namely the isothermal magnetic entropy change (), is evaluated from the magnetization data with and without demagnetization factor correction. The results indicate that without demagnetization factor correction the values are slightly underestimated. The difference between values with and without demagnetization factor correction increases with an increase in demagnetization factor. However, as the field increases, the variation/error in values due to uncertainties related to magnetization (M), field (H) and temperature (T) values becomes higher due to the demagnetization factor correction.},
  langid = {english}
}

