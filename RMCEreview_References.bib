  number = {1},
  pages = {18727},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-23661-4},
  urldate = {2026-03-31},
  abstract = {The ternary RMn2Ge2 (R\,=\,rare earth) intermetallic compounds have attracted great attention due to their interesting magnetic behaviors and magnetotransport responses. Here, we reported our observation of anisotropic magnetic property, magnetostriction, and magnetocaloric effect (MCE) in TbMn2Ge2 single crystal. Below the transition temperature of Tb magnetic sublattices (\$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$\,\textasciitilde\,95~K), strong Ising-like magnetocrystalline anisotropy is observed with an out-of-plane ferromagnetic moments 5.98 {$\mu$}B/f.u. along the easy c axis, which is two orders of magnitude larger than that of field along a axis. Above \$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$, a field-induced metamagnetic transition is observed from the spin-flip of Mn sublattices. During this transition, remarkable magnetostriction effect is observed, indicating of strong spin--lattice coupling. The responses of Tb and Mn sublattices to the magnetic field generate a giant magnetic entropy change (\$\$- \textbackslash Delta S\_\textbraceleft M\textbraceright\$\$) and large values of relative cooling power (RCP) and temperature-averaged entropy change (TEC). The calculated maximum magnetic entropy change (\$\$- \textbackslash Delta S\_\textbraceleft M\textbraceright\textasciicircum\textbraceleft\textbackslash max \textbraceright\$\$), RCP, and TEC(10) with magnetic field change of 7~T along c axis reach 24.02~J~kg-1~K-1, 378.4~J~kg-1, and 21.39~J~kg-1~K-1 near \$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$, which is the largest among RMn2Ge2 families. More importantly, this giant MCE shows plateau behavior with wide window temperatures from 93 to 108~K, making it be an attractive candidate for magnetic refrigeration applications.},
  copyright = {2022 The Author(s)},
  langid = {english},
  keywords = {Ferromagnetism,Magnetic properties and materials},
  file = {C:\Users\joaos\Zotero\storage\G2PL3GVC\Huang et al. - 2022 - Anisotropic magnetic property, magnetostriction, and giant magnetocaloric effect with plateau behavi.pdf}
}

@article{89,
  title = {Rotating Magnetocaloric Effect in Highly Anisotropic {{TbIII}} and {{DyIII}} Single Molecular Magnets},
  author = {Konieczny, Piotr and Czernia, Dominik and Kajiwara, Takashi},
  year = 2022,
  month = oct,
  journal = {Scientific Reports},
  volume = {12},
  number = {1},
  pages = {16601},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-20893-2},
  urldate = {2026-03-31},
  abstract = {The magnetocaloric effect (MCE) was investigated in highly anisotropic single crystals of two single molecule magnets (SMMs): [LnIII(ZnIIL)2]CF3SO3, where Ln\,=\,Tb, Dy and L\,=\,tripodal hexadentate Schiff base ligand. The structure of these paramagnetic compounds consists of identically oriented linear trinuclear clusters in a trigonal system with an easy direction c{$\parallel$}Zn--Ln--Zn array and a hard plane ab{$\perp$}Zn--Ln--Zn array. The magnitude of MCE measured for c{$\parallel$}H was significantly greater than MCE for ab{$\parallel$}H at a wide temperature range regardless of the studied SMM. Therefore, the rotating magnetocaloric effect (RMCE) was evaluated. The maxima of the magnetic entropy change for RMCE were obtained at 2.0~K and moderate fields: 3.9~J K-1 kg-1 at \textmu 0H\,=\,1.3~T for Ln\,=\,Tb and 3.3~J K-1 kg-1 at \textmu 0H\,=\,1.1~T for Ln\,=\,Dy. The relative efficiency of RMCE compared to the MCE measured in c{$\parallel$}H was as high as 99\% at low magnetic fields.},
  copyright = {2022 The Author(s)},
  langid = {english},
  keywords = {Ferromagnetism,Magnetic materials,Magnetic properties and materials},
  file = {C:\Users\joaos\Zotero\storage\CFXSEUS4\Konieczny et al. - 2022 - Rotating magnetocaloric effect in highly anisotropic TbIII and DyIII single molecular magnets.pdf}
}

@article{9_final,
  title = {Grain-Orientation Engineering Enables Dual-Functionality in ({{Mn}},{{Fe}})2({{P}},{{Si}})/Epoxy Composites: {{Colossal}} Negative Thermal Expansion and Anisotropic Magnetocaloric Effect},
  shorttitle = {Grain-Orientation Engineering Enables Dual-Functionality in ({{Mn}},{{Fe}})2({{P}},{{Si}})/Epoxy Composites},
  author = {Gong, Yong and Yan, Zhubing and Cugini, Francesco and Qian, Fengjiao and Lai, Jiawei and Miao, Xuefei and Liu, Jun and Qi, Zhixiang and Gong, Yuanyuan and Xu, Feng and Caron, Luana},
