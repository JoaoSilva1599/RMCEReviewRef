  urldate = {2026-04-01},
  abstract = {Lanthanide calcium oxyborate LnCa4O(BO3)3 compounds form a family of multifunctional materials with promising nonlinear and linear optical properties and piezoelectric properties because of their polar crystal structure. In the present work, we report their anisotropic magnetic properties through the study of single-crystalline lanthanide calcium oxyborate LnCa4O(BO3)3 samples with Ln = Pr, Nd, Gd, Er and Tm. A strong magnetic anisotropy was observed, mostly originating from the strong single-ion anisotropy and varies significantly from one magnetic Ln3+ ion to another. This causes a large rotating magnetocaloric effect (RMCE) in the helium liquid temperature range for the Nd, Er and Tm compounds. For the Nd and Er compound, the RMCE is larger than the polycrystalline MCE up to the largest investigated magnetic field, 7 T, whereas the RMCE is larger than the polycrystalline value below 4 T for the Tm and Er compounds. The RMCE of the Er compound also exceeds any polycrystalline MCE in this compound family below 3 T. This shows the exceptional potential of Er-based LnCOB for RMCE applications in the liquid He temperature range.},
  langid = {english},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\KQ4LWHKT\\Azrour et al. - 2025 - Large magnetic anisotropy and a rotating cryomagnetocaloric effect in single-crystalline paramagneti.pdf;C\:\\Users\\joaos\\Zotero\\storage\\NQVDZH8Z\\Azrour et al. - 2025 - Large magnetic anisotropy and a rotating cryomagnetocaloric effect in single-crystalline paramagneti.pdf}
}

@article{326_2,
  title = {Investigation on the Magnetocaloric Effect in {{DyNi2}}, {{DyAl2}} and {{Tb1}}-{\emph{n}}{{Gd}}{\emph{n}}{{Al2}} ({\emph{N}}=0, 0.4, 0.6) Compounds},
  author = {{de Sousa}, V. S. R. and Plaza, E. J. R. and Reis, M. S. and Alho, B. P. and Carvalho, A. Magnus G. and Gama, S. and {de Oliveira}, N. A. and {von Ranke}, P. J.},
  year = 2009,
  month = oct,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {321},
  number = {20},
  pages = {3462--3465},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2009.06.054},
  urldate = {2026-03-31},
  abstract = {The magnetocaloric effect (MCE) in the DyNi2, DyAl2 and Tb1-nGdnAl2 (n=0, 0.4, 0.6) was theoretically investigated in this work. The DyNi2 and DyAl2 compounds are described considering a model Hamiltonian which includes the crystalline electrical field anisotropy. The anisotropic MCE was calculated changing the magnetic field direction from \textlangle 111\textrangle{} to \textlangle 001\textrangle{} in DyNi2 and from \textlangle 100\textrangle{} to \textlangle 011\textrangle{} in DyAl2. The influence of the second- and first-order spin-reorientation phase transitions on the MCE that occurs in these systems is discussed. For the calculations of the MCE thermodynamic quantities in the Tb1-nGdnAl2 systems we take into account a two sites magnetic model, and good agreement with the available experimental data was obtained.},
  keywords = {Crystalline electrical field,Magnetocaloric effect},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\TBN9TKZ6\\de Sousa et al. - 2009 - Investigation on the magnetocaloric effect in DyNi2, DyAl2 and Tb1−nGdnAl2 (n=0.pdf;C\:\\Users\\joaos\\Zotero\\storage\\SH5AM5HX\\S030488530900674X.html}
}

@article{327,
  title = {Anisotropy of the Magnetocaloric Effect in {{DyNiAl}}},
  author = {Ka{\v s}til, J. and Javorsk{\'y}, P. and Andreev, A. V.},
  year = 2009,
  month = aug,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {321},
  number = {15},
  pages = {2318--2321},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2009.02.118},
  urldate = {2026-03-31},
  abstract = {We present study of the anisotropic magnetocaloric effect in DyNiAl. This compound crystallizes in the hexagonal ZrNiAl-type structure, orders magnetically below TC=31K and undergoes a further magnetic phase transition at T1=15K. The Dy-moments are aligned ferromagnetically along the hexagonal c-axis below TC, the additional antiferromagnetic component develops within the basal plane below T1. The magnetocaloric effect was evaluated from the magnetization measurements with field applied along the c-axis and perpendicular to it. Our data reveal a strong anisotropy of the magnetocaloric effect. The large effect occurs for field applied along the c-axis whereas the entropy change is small for the perpendicular field direction.},
  keywords = {Anisotropy,DyNiAl,Magnetism,Magnetocaloric effect},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\J5QLQTXI\\Kaštil et al. - 2009 - Anisotropy of the magnetocaloric effect in DyNiAl.pdf;C\:\\Users\\joaos\\Zotero\\storage\\3DM8XDW3\\S0304885309000833.html}
}

