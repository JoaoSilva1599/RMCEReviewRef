@article{308,
  title = {Magnetocaloric Effect in Single Crystal {{Nd2Co7}}},
  author = {Ilyn, M. and Bartashevich, M. I. and Andreev, A. V. and Tereshina, E. A. and Zhukova, V. and Zhukov, A. and Gonzalez, J.},
  year = 2011,
