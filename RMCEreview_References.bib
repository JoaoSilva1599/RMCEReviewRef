@article{64,
  title = {Highly {{Anisotropic Magnetism}} and {{Nearly Isotropic Magnetocaloric Effect}} in {{Mn3Sn2 Single Crystals}}},
  author = {Bai, Jianli and Dong, Qingxin and Zhang, Libo and Liu, Qiaoyu and Cheng, Jingwen and Liu, Pinyu and Li, Cundong and Sun, Yingrui and Huang, Yu and Ren, Zhian and Chen, Genfu},
  year = 2023,
