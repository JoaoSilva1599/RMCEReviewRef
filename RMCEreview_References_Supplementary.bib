  journal = {IEEE Transactions on Magnetics},
  volume = {52},
  number = {5},
  pages = {1--4},
  issn = {1941-0069},
  doi = {10.1109/TMAG.2016.2530138},
  urldate = {2026-03-31},
  abstract = {The adiabatic temperature change {$\Delta$}Tad and the isothermal entropy change {$\Delta$}Sm were measured in a Er2Fe14B single crystal in the temperature range of 250-370 K under a magnetic field change of {$\Delta\mu$}0H = 1.9 T. The magnetic field was applied along the crystallographic axes a and c. Under adiabatic conditions, the application of a 0.5 T field along the c-direction of the Er2Fe14B single crystal leads to a negative {$\Delta$}Tad at temperatures below the spin-reorientation temperature TSR = 323 K. In this case, the maximum {$\Delta$}Tad reaches -0.9 K in the temperature range of 270-280 K. Along the a-direction, the magnetocaloric effect above TSR is positive, and {$\Delta$}Tad reaches 0.68 K in the magnetic field 0.5 T at the temperatures of 320-330 K. Under isothermal conditions, the maximal magnetic entropy change is -0.86 J kg-1K-1 at 328 K when the magnetic field is applied along the a-direction and {$\Delta$}Sm = 1.27 J kg-1K-1 at 275 K if the single crystal is magnetized along the c-axis.},
  keywords = {Anisotropic magnetoresistance,Crystals,Magnetic anisotropy,Magnetic fields,magnetic refrigeration,Magnetic refrigeration,Magnetization,magnetocaloric materials,Magnetocaloric materials,Perpendicular magnetic anisotropy,Spin-reorientation transition,spin-reorientation transition (SRT),Temperature measurement},
  file = {C:\Users\joaos\Zotero\storage\4CD42X9K\Skokov et al. - 2016 - Rotational Magnetocaloric Effect in the Er2Fe14B Single Crystal.pdf}
}

