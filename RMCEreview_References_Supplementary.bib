@article{289,
  title = {Theoretical Investigations on the Magnetocaloric and Barocaloric Effects in {{Tb}}{\emph{y}}{{Gd}}(1-{\emph{y}}){{Al2}} Series},
  author = {Ribeiro, P. O. and Alho, B. P. and Alvarenga, T. S. T. and N{\'o}brega, E. P. and Carvalho, A. Magnus G. and {de Sousa}, V. S. R. and Caldas, A. and {de Oliveira}, N. A. and {von Ranke}, P. J.},
