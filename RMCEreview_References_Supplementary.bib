}

@article{271,
  title = {Magnetic Field Influence on the {{N}}\textbackslash 'eel, Dimer, and Spin-Liquid States of the Low-Dimensional Antiferromagnets \$\textbraceleft\textbackslash mathrm\textbraceleft{{NiTa}}\textbraceright\textbraceright\_\textbraceleft 2\textbraceright\textbraceleft\textbackslash mathrm\textbraceleft{{O}}\textbraceright\textbraceright\_\textbraceleft 6\textbraceright\$ and \$\textbraceleft\textbackslash mathrm\textbraceleft{{CoSb}}\textbraceright\textbraceright\_\textbraceleft 2\textbraceright\textbraceleft\textbackslash mathrm\textbraceleft{{O}}\textbraceright\textbraceright\_\textbraceleft 6\textbraceright\$},
