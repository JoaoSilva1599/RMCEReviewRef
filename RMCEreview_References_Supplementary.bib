  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2017.05.078},
  urldate = {2026-03-31},
  abstract = {Interesting behaviors in the magnetocaloric effect and magnetoresistivity are predicted for cubic CsCl-type TmZn compound in which, recently, the giant magnetocaloric effect was reported. Our model includes the crystalline electrical field, exchange, Zeeman and elastic-quadrupolar interactions. The calculated giant magnetocaloric effect is in agreement with the experimental data upon magnetic field variation along the easy magnetic direction \textlangle 001\textrangle. For applied magnetic field direction \textlangle 110\textrangle an inverse magnetocaloric effect was predicted in the temperature range from 0.7 to 8.2K. For applied magnetic field along \textlangle 111\textrangle direction, a discontinuity in magnetic entropy change was predicted at 14.1K leading to a latent heat of 80J/mol and magnetic entropy change of 36Jmol-1K-1 in the field change from zero to 5T. Besides, strong correlation between the anisotropic magnetoresistivity and magnetocaloric effects was reported.},
  keywords = {Crystal field interaction,Magnetocaloric effect,Magnetoresistance},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\74G6ZWK2\\von Ranke et al. - 2017 - The influence of dipolar and quadrupolar interactions on the magnetoresistivity and magnetocaloric e.pdf;C\:\\Users\\joaos\\Zotero\\storage\\W3RAJIDW\\S0304885317300215.html}
}

@article{217,
