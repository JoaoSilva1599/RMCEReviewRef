@article{85,
  title = {Anisotropy of Magnetocaloric Effect and Rotating Magnetocaloric Effect in {{2D}} Coordination Polymer Based on \textbraceleft{{CuII}}[{{WV}}({{CN}})8]\textbraceright - and Adeninium Cations},
  author = {Konieczny, Piotr and Pe{\l}ka, Robert and Ku{\'z}niak, Emilia and Podgajny, Robert},
  year = 2022,
  month = dec,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {563},
  pages = {170001},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2022.170001},
  urldate = {2026-03-31},
  abstract = {Anisotropy of conventional magnetocaloric effect (MCE) and rotating magnetocaloric effect (RMCE) have been investigated in quasi-two-dimensional coordination polymer (AdeH)\textbraceleft CuII[WV(CN)8]\textbraceright{$\cdot$}2H2O with high magnetic anisotropy and topological phase transition. Magnetic entropy changes ({$\Delta$}Smag) were calculated from magnetic measurements of single crystals in three orthogonal directions, H\textbar\textbar a*, H\textbar\textbar b and H\textbar\textbar c. The highest {$\Delta$}Smag~=~3.49~J~K-1 kg-1 was recorded for conventional MCE in the H\textbar\textbar c direction for \textmu 0\textbar{$\Delta$}H\textbar =7.0~T and at a peak temperature of 37.5~K. The RMCE was calculated for the rotation around the b axis by 90{$^\circ$} from H\textbar\textbar a* to H\textbar\textbar c with the maximal {$\Delta$}Smag of 1.62~J~K-1 kg-1 detected for \textmu 0H~=~7.0~T at 38~K.},
  keywords = {2D magnetism,Magnetic anisotropy,Magnetocaloric effect,Rotating magnetocaloric effect},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\JW5AAVXD\\Konieczny et al. - 2022 - Anisotropy of magnetocaloric effect and rotating magnetocaloric effect in 2D coordination polymer ba.pdf;C\:\\Users\\joaos\\Zotero\\storage\\K5GITQUL\\S0304885322008861.html}
}

@article{87,
  title = {Anisotropic Magnetic Property, Magnetostriction, and Giant Magnetocaloric Effect with Plateau Behavior in {{TbMn2Ge2}} Single Crystal},
  author = {Huang, Shuai and Bai, Yuming and Wan, Kaiqi and Zhu, Changming and Huo, Dexuan and Tian, Zhaoming},
  year = 2022,
  month = nov,
  journal = {Scientific Reports},
  volume = {12},
  number = {1},
  pages = {18727},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-23661-4},
  urldate = {2026-03-31},
  abstract = {The ternary RMn2Ge2 (R\,=\,rare earth) intermetallic compounds have attracted great attention due to their interesting magnetic behaviors and magnetotransport responses. Here, we reported our observation of anisotropic magnetic property, magnetostriction, and magnetocaloric effect (MCE) in TbMn2Ge2 single crystal. Below the transition temperature of Tb magnetic sublattices (\$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$\,\textasciitilde\,95~K), strong Ising-like magnetocrystalline anisotropy is observed with an out-of-plane ferromagnetic moments 5.98 {$\mu$}B/f.u. along the easy c axis, which is two orders of magnitude larger than that of field along a axis. Above \$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$, a field-induced metamagnetic transition is observed from the spin-flip of Mn sublattices. During this transition, remarkable magnetostriction effect is observed, indicating of strong spin--lattice coupling. The responses of Tb and Mn sublattices to the magnetic field generate a giant magnetic entropy change (\$\$- \textbackslash Delta S\_\textbraceleft M\textbraceright\$\$) and large values of relative cooling power (RCP) and temperature-averaged entropy change (TEC). The calculated maximum magnetic entropy change (\$\$- \textbackslash Delta S\_\textbraceleft M\textbraceright\textasciicircum\textbraceleft\textbackslash max \textbraceright\$\$), RCP, and TEC(10) with magnetic field change of 7~T along c axis reach 24.02~J~kg-1~K-1, 378.4~J~kg-1, and 21.39~J~kg-1~K-1 near \$\$T\_\textbraceleft\textbraceleft\textbackslash text\textbraceleft C\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft\textbraceleft\textbraceleft\textbackslash text\textbraceleft Tb\textbraceright\textbraceright\textbraceright\textbraceright\$\$, which is the largest among RMn2Ge2 families. More importantly, this giant MCE shows plateau behavior with wide window temperatures from 93 to 108~K, making it be an attractive candidate for magnetic refrigeration applications.},
  copyright = {2022 The Author(s)},
  langid = {english},
  keywords = {Ferromagnetism,Magnetic properties and materials},
  file = {C:\Users\joaos\Zotero\storage\G2PL3GVC\Huang et al. - 2022 - Anisotropic magnetic property, magnetostriction, and giant magnetocaloric effect with plateau behavi.pdf}
}

@article{89,
  title = {Rotating Magnetocaloric Effect in Highly Anisotropic {{TbIII}} and {{DyIII}} Single Molecular Magnets},
  author = {Konieczny, Piotr and Czernia, Dominik and Kajiwara, Takashi},
  year = 2022,
  month = oct,
  journal = {Scientific Reports},
  volume = {12},
  number = {1},
  pages = {16601},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-20893-2},
  urldate = {2026-03-31},
  abstract = {The magnetocaloric effect (MCE) was investigated in highly anisotropic single crystals of two single molecule magnets (SMMs): [LnIII(ZnIIL)2]CF3SO3, where Ln\,=\,Tb, Dy and L\,=\,tripodal hexadentate Schiff base ligand. The structure of these paramagnetic compounds consists of identically oriented linear trinuclear clusters in a trigonal system with an easy direction c{$\parallel$}Zn--Ln--Zn array and a hard plane ab{$\perp$}Zn--Ln--Zn array. The magnitude of MCE measured for c{$\parallel$}H was significantly greater than MCE for ab{$\parallel$}H at a wide temperature range regardless of the studied SMM. Therefore, the rotating magnetocaloric effect (RMCE) was evaluated. The maxima of the magnetic entropy change for RMCE were obtained at 2.0~K and moderate fields: 3.9~J K-1 kg-1 at \textmu 0H\,=\,1.3~T for Ln\,=\,Tb and 3.3~J K-1 kg-1 at \textmu 0H\,=\,1.1~T for Ln\,=\,Dy. The relative efficiency of RMCE compared to the MCE measured in c{$\parallel$}H was as high as 99\% at low magnetic fields.},
  copyright = {2022 The Author(s)},
  langid = {english},
  keywords = {Ferromagnetism,Magnetic materials,Magnetic properties and materials},
  file = {C:\Users\joaos\Zotero\storage\CFXSEUS4\Konieczny et al. - 2022 - Rotating magnetocaloric effect in highly anisotropic TbIII and DyIII single molecular magnets.pdf}
}

@article{9_final,
  title = {Grain-Orientation Engineering Enables Dual-Functionality in ({{Mn}},{{Fe}})2({{P}},{{Si}})/Epoxy Composites: {{Colossal}} Negative Thermal Expansion and Anisotropic Magnetocaloric Effect},
  shorttitle = {Grain-Orientation Engineering Enables Dual-Functionality in ({{Mn}},{{Fe}})2({{P}},{{Si}})/Epoxy Composites},
  author = {Gong, Yong and Yan, Zhubing and Cugini, Francesco and Qian, Fengjiao and Lai, Jiawei and Miao, Xuefei and Liu, Jun and Qi, Zhixiang and Gong, Yuanyuan and Xu, Feng and Caron, Luana},
  year = 2026,
  month = mar,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {641},
  pages = {173809},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2025.173809},
  urldate = {2026-04-01},
  abstract = {The \textlangle 001\textrangle ~-~oriented (Mn,Fe)2(P,Si)/epoxy composites were fabricated via magnetic field-assisted dynamic self-assembly. These textured composites demonstrate remarkable adaptability for diverse applications that require either substantial coefficients ({$\alpha$}l) of negative thermal expansion (NTE) or broad NTE temperature windows ({$\Delta$}TNTE). A two-dimensional NTE with a colossal {$\alpha$}l of -144.37~\texttimes ~10-6~K-1 is realized between 280 and 360~K in the composite displaying a first-order phase transition (FOPT). The {$\Delta$}TNTE can be significantly extended to 190~K (120-310K) in the composite exhibiting a second-order phase transition (SOPT), while preserving a large {$\alpha$}l of -23.89~\texttimes ~10-6~K-1. Besides that, anisotropic MCE is observed in the textured composites. The FOPT composite exhibits a maximum entropy change of 7.18 Jkg-1~K-1 under a magnetic field of 1~T applied perpendicular to the texture direction, which is 34~\% higher than the parallel field configuration. Consequently, our study demonstrates that grain-orientation engineering can be effectively employed to explore NTE and achieve anisotropic magnetocaloric properties.},
  keywords = {(MnFe)(PSi),Magnetic phase transition,Magnetocaloric effect,Negative thermal expansion},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\ZJ8FG26F\\Gong et al. - 2026 - Grain-orientation engineering enables dual-functionality in (Mn,Fe)2(P,Si)epoxy composites Colossa.pdf;C\:\\Users\\joaos\\Zotero\\storage\\JV9RWFWB\\S0304885325010455.html}
}

@article{93,
  title = {{Magnetic and anisotropic magnetocaloric effects of HoCoSi fast quenching ribbons}},
  author = {Yan, Zhang and {Shuo-Tong}, Zong and {Zhi-Gang}, Sun and {Hong-Xia}, Liu and {Feng-Hua}, Chen and {Ke-Wei}, Zhang and {Ji-Fan}, Hu and {Tong-Yun}, Zhao and {Bao-Gen}, Shen},
  year = 2022,
  month = aug,
  journal = {Acta Physica Sinica},
  volume = {71},
  number = {16},
  pages = {167501--7},
  issn = {1000-3290},
  doi = {10.7498/aps.71.20220683},
  urldate = {2026-03-31},
  abstract = {The performance of magnetocaloric effect materials is one of the key factors restricting the development of magnetic refrigeration technology. Materials with anisotropic magnetocaloric effect can be used in the rotary magnetic refrigeration technology, which is beneficial to the simplification of refrigeration devices. In this work, the magnetic properties, magnetocaloric effects, and magnetic anisotropies of rapidly quenched HoCoSi compounds are investigated. At low temperatures below \emph{T}\textsubscript{t} = 5.7 K, the HoCoSi ferromagnetism and helical magnetism coexist. With the increase of temperature, the HoCoSi undergoes a second-order phase transition from ferromagnetic (FM) to paramagnetic (PM) phase at \emph{T}\textsubscript{C} = 13.7 K. Both XRD and SEM show that the HoCoSi has a preferred orientation. In order to obtain a large magnetocaloric effect and to determine the effect of preferred orientation on magnetism and magnetocaloric effect, the isothermal magnetization curves of the 10 m/s--HoCoSi fast quenched belt in the directions of \emph{H} parallel  and perpendicular to texture around the Curie temperature are analyzed. The corresponding magnetic entropy change (--{$\Delta$}\emph{S}\textsubscript{M}) and magnetic refrigeration capacity (RC) are calculated. Under the magnetic field changing from 0 to 5 T, the value of --{$\Delta$}\emph{S}\textsubscript{M} is 22 J/(kg{$\cdot$}K) in the direction of \emph{H} parallel to the texture and 12 J/(kg{$\cdot$}K) in the direction of \emph{H} perpendicular to texture , and their corresponding values of RC(RCP)are 360 (393.8) J{$\cdot$}kg\textsuperscript{--1} and 160 (254.4) J/kg. The value of --{$\Delta$}\emph{S}\textsubscript{M} reaches 12.5 J/(kg{$\cdot$}K)even at \emph{{$\mu$}}\textsubscript{0}\emph{H} = 0--2 T in the direction of H parallel to the texture. It is obvious that the 10-m/s-HoCoSi fast quenching belt shows a large low-field magnetocaloric effect and obvious magnetic anisotropy, which is expected to be used to realize the magnetic refrigeration technology of rotating samples.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  langid = {chinese},
  file = {C:\Users\joaos\Zotero\storage\X9ZUU8FP\Yan et al. - 2022 - Magnetic and anisotropic magnetocaloric effects of HoCoSi fast quenching ribbons.pdf}
}

@article{97,
  title = {Structure, Magnetic Anisotropy and Magnetocaloric Effect of {{Mn5Ge3-xSix}} Single Crystals},
  author = {Yang, Tonghan and He, Wei and Chen, Feikuo and He, Cuiyun},
  year = 2022,
  month = oct,
  journal = {Journal of Magnetism and Magnetic Materials},
  volume = {559},
  pages = {169539},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2022.169539},
  urldate = {2026-03-31},
  abstract = {Magnetocaloric polycrystalline materials based on Mn5Ge3 have been widely studied due to their potential application for room temperature magnetic refrigeration. However, many investigations are performed on polycrystalline materials and thus the strong anisotropy in this layered structure is usually neglected. In this study, Mn5Ge3-xSix (x~=~0, 0.7) single crystals were successfully synthesized via Sn flux and characterized by single-crystal X-ray diffraction and magnetic measurements. The Si substitution does not change the structural symmetry, but reduces the shortest Mn~-~Mn distances. As described by the Bethe-Slater curve, the reduction of the shortest Mn~-~Mn distances leads to weaker magnetic exchange, accounting for the lower ordering temperature. The magnetocrystalline anisotropy was evaluated by the Sucksmith and Thompson method, and became smaller upon substitution. The anisotropy constants K1 and K2 of Mn5Ge3-xSix (x~=~0, 0.7) single crystals are positive, and decrease with the temperature. The electron paramagnetic resonance spectra suggest high spin d5 configuration of manganese in both crystals. The easy magnetization direction yields much larger maximum entropy changes in both crystals: 6.0~J/kg K for the pristine and 5.4~J/kg K for the substituted under an applied field of 30 kOe.},
  keywords = {Exchange interactions,Magnetic anisotropy,Magnetocaloric effect,Single crystal},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\V2BRHER9\\Yang et al. - 2022 - Structure, magnetic anisotropy and magnetocaloric effect of Mn5Ge3-xSix single crystals.pdf;C\:\\Users\\joaos\\Zotero\\storage\\563BUBZV\\S0304885322004607.html}
}

@article{real_0,
  title = {Giant Reversible Rotating Cryomagnetocaloric Effect in \$\textbackslash mathrm\textbraceleft{{KEr}}\textbraceright (\textbraceleft\textbackslash text\textbraceleft{{MoO}}\textbraceright\textbraceright\_\textbraceleft 4\textbraceright )\textbraceleft\textbraceright\_\textbraceleft 2\textbraceright\$ Induced by a Crystal-Field Anisotropy},
  author = {Tk{\'a}{\v c}, V. and Orend{\'a}{\v c}ov{\'a}, A. and {\v C}i{\v z}m{\'a}r, E. and Orend{\'a}{\v c}, M. and Feher, A. and Anders, A. G.},
  year = 2015,
  month = jul,
  journal = {Physical Review B},
  volume = {92},
  number = {2},
  pages = {024406},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevB.92.024406},
  urldate = {2026-04-01},
  abstract = {Magnetocaloric properties of KEr⁡(MoO4)2 single crystals were investigated using magnetization and specific heat measurements in the magnetic field applied along the easy and hard axis. Large conventional magnetocaloric effect was found around 10 K (-{$\Delta$}⁢{$S$}max =14 J/kg K for 5 T) in the field applied along the easy axis. What is more, a huge magnetic anisotropy in the {$a$}⁢{$b$} plane leads to a large anisotropy of magnetocaloric effect, -{$\Delta$}⁢{$S$}R,max =10 and 13 J/kg K obtained by a simple rotating of the single crystal within the {$a$}⁢{$b$} plane in the constant magnetic field 2 and 5 T, respectively. Large {$\Delta$}⁢{$S$}R values with no hysteresis losses and rather wide working temperature spans imply that KEr⁡(MoO4)2 may serve as a promising candidate for the implementation of a compact rotary magnetic cryorefrigerator.},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\JMSR55R4\\Tkáč et al. - 2015 - Giant reversible rotating cryomagnetocaloric effect in $mathrm KEr ( text MoO _ 4 ) _ 2 $ induce.pdf;C\:\\Users\\joaos\\Zotero\\storage\\5N6RJCBR\\PhysRevB.92.html}
}
