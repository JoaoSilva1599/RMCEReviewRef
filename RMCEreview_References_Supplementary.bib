  file = {C:\Users\joaos\Zotero\storage\TUFFLFH5\Bai et al. - 2023 - Highly Anisotropic Magnetism and Nearly Isotropic Magnetocaloric Effect in Mn3Sn2 Single Crystals.pdf}
}

