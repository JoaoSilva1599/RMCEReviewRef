  title = {Experimental and Computational {{Insights Into}} the Magnetic Anisotropy and Magnetic Behaviour of Layered Room-Temperature Ferromagnet {{Cr1}}.{{38Te2}}},
  author = {Purwar, Shubham and Bhowmik, Tushar Kanti and Rajesh, Tijare Mandar and Gorai, Anupam and Chittari, Bheema Lingam and Thirupathaiah, Setti},
