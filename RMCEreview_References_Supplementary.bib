  doi = {10.1021/acs.jpcc.1c06285},
  urldate = {2026-03-31},
  abstract = {Single crystals of a hexagonal ferromagnet NdCrGe3 with one-dimensional crystal structure are synthesized, and the magnetic properties are comprehensively investigated, exhibiting large magnetic anisotropy and complex magnetic structure. Besides the ferromagnetic transition at TC = 101 K, we observe a sharp decrease in magnetization at T = 55 K and another two phase transitions at T = 31 and 15 K. These phase transitions imply complex and anisotropic magnetic structure in NdCrGe3. Below T = 55 K, metamagnetic transitions and negative magnetocaloric effects are detected under H//ab. Additionally, the critical properties around TC = 101 K and the anisotropic magnetocaloric effect are investigated in detail.},
