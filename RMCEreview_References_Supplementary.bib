@article{194,
  title = {Anisotropic Magnetic Properties and Giant Rotating Magnetocaloric Effect in Double-Perovskite \$\textbackslash mathrm\textbraceleft{{T}}\textbraceright\textbraceleft\textbackslash mathrm\textbraceleft b\textbraceright\textbraceright\_\textbraceleft 2\textbraceright\textbackslash mathrm\textbraceleft{{CoMn}}\textbraceright\textbraceleft\textbackslash mathrm\textbraceleft{{O}}\textbraceright\textbraceright\_\textbraceleft 6\textbraceright\$},
  author = {Moon, J. Y. and Kim, M. K. and Oh, D. G. and Kim, J. H. and Shin, H. J. and Choi, Y. J. and Lee, N.},
  year = 2018,
  month = nov,
  journal = {Physical Review B},
  volume = {98},
  number = {17},
  pages = {174424},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevB.98.174424},
  urldate = {2026-03-31},
  abstract = {We investigated the anisotropy of the magnetic and magnetocaloric properties of single-crystalline double-perovskite T⁢b2⁢CoMn⁢O6, which crystallizes in a monoclinic {$P$}⁢21/{$n$} structure. Due to dissimilar magnetic anisotropy, the ferromagnetic order of the C⁢o2+ and M⁢n4+ moments emerges along the {$c$} axis at {$T$}C=100K, and the larger T⁢b3+ moments align perpendicular to the {$c$} axis, below {$T$}Tb=15K. The intricate temperature development of the metamagnetism along the {$c$} axis results in a large negative change in the magnetic entropy at low temperature. On the other hand, the larger but almost reversible magnetization, perpendicular to the {$c$} axis, results in a small and positive entropy change. This highly anisotropic magnetocaloric effect (MCE) leads to a giant rotational MCE, estimated to be 20.8⁢J/kg⁢K. Our findings, based on the magnetic anisotropy in T⁢b2⁢CoMn⁢O6, enrich fundamental and applied research on magnetic materials, considering the distinct magnetic characteristics of double perovskites.},
  file = {C\:\\Users\\joaos\\Zotero\\storage\\2WFVB6PE\\Moon et al. - 2018 - Anisotropic magnetic properties and giant rotating magnetocaloric effect in double-perovskite $math.pdf;C\:\\Users\\joaos\\Zotero\\storage\\VVHN4GPX\\PhysRevB.98.html}
}

